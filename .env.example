# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_app_client_id

# Clash Royale API
CR_API_KEY=your_clash_royale_api_key
CR_API_BASE_URL=https://proxy.royaleapi.dev/v1

# Clash Royale Developer Portal (opcional - para auto-update de IP)
CR_DEV_EMAIL=your_developer_email
CR_DEV_PASSWORD=your_developer_password
CR_API_KEY_ID=your_api_key_id

# Database (PostgreSQL)
DATABASE_URL=postgresql://clashbot:your_password@postgres:5432/clashbot
DB_USER=clashbot
DB_PASSWORD=your_secure_password

# Clan
CLAN_TAG=#28P8RQUY

# Thresholds
INACTIVITY_THRESHOLD_DAYS=2
VACATION_MAX_DAYS=20

# Server
HEALTHCHECK_PORT=3000

# Logging
LOG_LEVEL=info
