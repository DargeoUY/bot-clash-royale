# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_app_client_id

# Clash Royale API
# Crear key en https://developer.clashroyale.com
# Whitelist IP: 45.79.218.79 (IP del proxy)
CR_API_KEY=your_clash_royale_api_key
CR_API_BASE_URL=https://proxy.royaleapi.dev/v1

# Database (PostgreSQL)
DATABASE_URL=postgresql://clashbot:your_password@localhost:5432/clashbot
DB_USER=clashbot
DB_PASSWORD=your_secure_password

# Clan (tag por defecto)
CLAN_TAG=#28P8RQUY

# Thresholds
INACTIVITY_THRESHOLD_DAYS=2
VACATION_MAX_DAYS=20

# Server
HEALTHCHECK_PORT=3000

# Logging
LOG_LEVEL=info

# Telegram (bot único para notificaciones)
# Crear bot con @BotFather → https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
