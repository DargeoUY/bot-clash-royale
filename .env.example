# Discord
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_secret

# Clash Royale API
CR_API_KEY=your_clash_royale_api_key
CR_API_BASE_URL=https://api.clashroyale.com/v1

# Clash Royale Developer Portal (opcional - para auto-update de IP)
CR_DEV_EMAIL=your_developer_email
CR_DEV_PASSWORD=your_developer_password
CR_API_KEY_ID=your_api_key_id

# Database (MariaDB)
DATABASE_URL=mysql://clashbot:password@mariadb:3306/clashbot
DB_USER=clashbot
DB_PASSWORD=password
DB_ROOT_PASSWORD=root_password

# Clan
CLAN_TAG=#28P8RQUY

# Thresholds
INACTIVITY_THRESHOLD_DAYS=2
VACATION_MAX_DAYS=20

# Server
HEALTHCHECK_PORT=3000
BASE_URL=http://localhost:3000

# Telegram (opcional)
TELEGRAM_TOKEN=

# Web
SESSION_SECRET=random_secret_here

# Logging
LOG_LEVEL=info
