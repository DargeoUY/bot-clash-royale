generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Clan {
  id             Int       @id @default(autoincrement())
  tag            String    @unique
  name           String
  description    String?
  level          Int?
  totalMiembros  Int?
  idServidorDiscord String?
  idChatTelegram    BigInt?
  esPrincipal    Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt()

  jugadores        Jugador[]
  registrosGuerra  RegistroGuerra[]
  configuraciones  ConfiguracionBot[]
}

model Jugador {
  id             Int       @id @default(autoincrement())
  tag            String    @unique
  name           String
  role           String?
  expLevel       Int?
  trophies       Int?
  clanTag        String?
  idDiscord      String?
  idTelegram     String?
  registrado     Boolean   @default(false)
  status         String    @default("active")
  ultimaActividad DateTime?
  salioEn        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt()

  clan               Clan?                  @relation(fields: [clanTag], references: [tag])
  participaciones    ParticipanteGuerra[]
  puntos             PuntoJugador[]
  registrosInactividad RegistroInactividad[]
  historialPuntos    HistorialPunto[]
  vacaciones         Vacacion[]
  donaciones         RegistroDonacion[]
  historialClan      HistorialClan[]
}

model RegistroGuerra {
  id             Int       @id @default(autoincrement())
  clanTag        String
  idTemporada    String?
  tipoGuerra     String
  startDate      DateTime
  endDate        DateTime?
  participantes  Int?
  batallasJugadas Int?
  wins           Int?
  losses         Int?
  fame           Int?
  createdAt       DateTime  @default(now())

  clan             Clan                 @relation(fields: [clanTag], references: [tag])
  participaciones  ParticipanteGuerra[]
}

model ParticipanteGuerra {
  id                Int       @id @default(autoincrement())
  idRegistroGuerra  Int
  tagJugador        String
  batallasJugadas   Int       @default(0)
  batallasGanadas   Int       @default(0)
  batallasPerdidas  Int       @default(0)
  mazosUsados       Int       @default(0)
  mazosUsadosHoy    Int?
  barcosAtacados    Int?
  puntosReparacion  Int?
  fame              Int?
  createdAt          DateTime  @default(now())

  registroGuerra RegistroGuerra @relation(fields: [idRegistroGuerra], references: [id])
  jugador        Jugador       @relation(fields: [tagJugador], references: [tag])

  @@unique([idRegistroGuerra, tagJugador])
}

model PuntoJugador {
  id             Int       @id @default(autoincrement())
  tagJugador     String
  puntosTotales  Int       @default(0)
  puntosGuerra   Int       @default(0)
  puntosActividad Int      @default(0)
  puntosExtra    Int       @default(0)
  season         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt()

  jugador        Jugador   @relation(fields: [tagJugador], references: [tag])

  @@unique([tagJugador, season])
}

model HistorialPunto {
  id          Int       @id @default(autoincrement())
  tagJugador  String
  points      Int
  razon       String
  description String?
  season      String?
  createdAt    DateTime  @default(now())

  jugador     Jugador   @relation(fields: [tagJugador], references: [tag])
}

model RegistroInactividad {
  id               Int       @id @default(autoincrement())
  tagJugador       String
  diasInactivo     Int
  notificadoEn     DateTime?
  vecesNotificado  Int       @default(0)
  status           String    @default("active")
  ultimaNotificacion DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt()

  jugador          Jugador   @relation(fields: [tagJugador], references: [tag])
}

model Vacacion {
  id         Int       @id @default(autoincrement())
  tagJugador String
  reason     String?
  startDate  DateTime
  endDate    DateTime
  activo     Boolean   @default(true)
  creadoPor  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt()

  jugador    Jugador   @relation(fields: [tagJugador], references: [tag])
}

model RegistroDonacion {
  id                 Int       @id @default(autoincrement())
  tagJugador         String
  donations          Int       @default(0)
  donacionesRecibidas Int      @default(0)
  season             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt()

  jugador            Jugador   @relation(fields: [tagJugador], references: [tag])

  @@unique([tagJugador, season])
}

model ConfiguracionBot {
  id        Int      @id @default(autoincrement())
  clanTag   String?
  clave     String   @unique
  valor     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  clan      Clan?    @relation(fields: [clanTag], references: [tag])
}

model HistorialClan {
  id            Int      @id @default(autoincrement())
  tagJugador    String
  clanTag       String
  evento        String
  nombreJugador String?
  createdAt      DateTime @default(now())

  jugador       Jugador  @relation(fields: [tagJugador], references: [tag])
}

model ConexionTelegram {
  id        Int      @id @default(autoincrement())
  codigo    String   @unique
  chatId    BigInt?
  guildId   String?
  usado     Boolean  @default(false)
  expiraEn  DateTime
  createdAt DateTime @default(now())
}
