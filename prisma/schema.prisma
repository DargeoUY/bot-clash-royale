generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Clan {
  id             Int       @id @default(autoincrement())
  tag            String    @unique @db.VarChar(15)
  name           String    @db.VarChar(100)
  description    String?   @db.Text
  level          Int?
  memberCount    Int?
  discordGuildId String?   @db.VarChar(30)
  isPrimary      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt()

  players        Player[]
  warLogs        WarLog[]
  botConfigs     BotConfig[]
}

model Player {
  id            Int       @id @default(autoincrement())
  tag           String    @unique @db.VarChar(15)
  name          String    @db.VarChar(100)
  role          String?   @db.VarChar(20)
  expLevel      Int?
  trophies      Int?
  clanTag       String?   @db.VarChar(15)
  discordId     String?   @db.VarChar(30)
  telegramId    String?   @unique @db.VarChar(30)
  isRegistered  Boolean   @default(false)
  phone         String?   @db.VarChar(30)
  status        String    @default("active") @db.VarChar(20)
  lastActiveAt  DateTime?
  leftAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt()

  clan            Clan?             @relation(fields: [clanTag], references: [tag])
  warParticipants WarParticipant[]
  points          PlayerPoint[]
  inactivityLogs  InactivityLog[]
  pointHistory    PointHistory[]
  vacations       Vacation[]
  donations       DonationLog[]
  clanHistory     ClanHistory[]
}

model WarLog {
  id             Int       @id @default(autoincrement())
  clanTag        String    @db.VarChar(15)
  seasonId       String?   @db.VarChar(50)
  warType        String    @db.VarChar(20)
  startDate      DateTime
  endDate        DateTime?
  participants   Int?
  battlesPlayed  Int?
  wins           Int?
  losses         Int?
  fame           Int?
  createdAt      DateTime  @default(now())

  clan            Clan              @relation(fields: [clanTag], references: [tag])
  warParticipants WarParticipant[]
}

model WarParticipant {
  id             Int       @id @default(autoincrement())
  warLogId       Int
  playerTag      String    @db.VarChar(15)
  battlesPlayed  Int       @default(0)
  battlesWon     Int       @default(0)
  battlesLost    Int       @default(0)
  decksUsed      Int       @default(0)
  decksUsedToday Int?
  boatsAttacked  Int?
  repairPoints   Int?
  fame           Int?
  createdAt      DateTime  @default(now())

  warLog         WarLog    @relation(fields: [warLogId], references: [id])
  player         Player    @relation(fields: [playerTag], references: [tag])

  @@unique([warLogId, playerTag])
}

model PlayerPoint {
  id             Int       @id @default(autoincrement())
  playerTag      String    @db.VarChar(15)
  totalPoints    Int       @default(0)
  warPoints      Int       @default(0)
  activityPoints Int       @default(0)
  bonusPoints    Int       @default(0)
  season         String?   @db.VarChar(20)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt()

  player         Player    @relation(fields: [playerTag], references: [tag])

  @@unique([playerTag, season])
}

model PointHistory {
  id          Int       @id @default(autoincrement())
  playerTag   String    @db.VarChar(15)
  points      Int
  reason      String    @db.VarChar(50)
  description String?   @db.Text
  season      String?   @db.VarChar(20)
  createdAt   DateTime  @default(now())

  player      Player    @relation(fields: [playerTag], references: [tag])
}

model InactivityLog {
  id             Int       @id @default(autoincrement())
  playerTag      String    @db.VarChar(15)
  daysInactive   Int
  notifiedAt     DateTime?
  notifiedCount  Int       @default(0)
  status         String    @default("active") @db.VarChar(20)
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt()

  player         Player    @relation(fields: [playerTag], references: [tag])
}

model Vacation {
  id         Int       @id @default(autoincrement())
  playerTag  String    @db.VarChar(15)
  reason     String?   @db.Text
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean   @default(true)
  createdBy  String    @db.VarChar(30)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt()

  player     Player    @relation(fields: [playerTag], references: [tag])
}

model DonationLog {
  id               Int       @id @default(autoincrement())
  playerTag        String    @db.VarChar(15)
  donations        Int       @default(0)
  donationsReceived Int      @default(0)
  season           String?   @db.VarChar(20)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt()

  player           Player    @relation(fields: [playerTag], references: [tag])

  @@unique([playerTag, season])
}

model BotConfig {
  id        Int      @id @default(autoincrement())
  clanTag   String?  @db.VarChar(15)
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt()

  clan      Clan?    @relation(fields: [clanTag], references: [tag])
}

model ClanHistory {
  id         Int      @id @default(autoincrement())
  playerTag  String   @db.VarChar(15)
  clanTag    String   @db.VarChar(15)
  event      String   @db.VarChar(20)
  playerName String?  @db.VarChar(100)
  createdAt  DateTime @default(now())

  player     Player   @relation(fields: [playerTag], references: [tag])
}

model PuntoGuardado {
  id              Int      @id @default(autoincrement())
  playerTag       String   @db.VarChar(15)
  dia             Int
  mes             Int
  anio            Int
  clanTag         String   @db.VarChar(15)
  partidasGanadas Int      @default(0)
  partidasPerdidas Int     @default(0)
  cartasDonadas   Int      @default(0)
  trofeos         Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([playerTag, dia, mes, anio])
  @@index([clanTag])
}

model DeltaDiario {
  id              Int      @id @default(autoincrement())
  playerTag       String   @db.VarChar(15)
  dia             Int
  mes             Int
  anio            Int
  hora            Int      @default(0)
  minuto          Int      @default(0)
  clanTag         String   @db.VarChar(15)
  partidasGanadas Int      @default(0)
  partidasPerdidas Int     @default(0)
  cartasDonadas   Int      @default(0)
  trofeos         Int      @default(0)
  fama            Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([playerTag, dia, mes, anio])
  @@index([clanTag])
}

model AcumuladoSemanal {
  id              Int      @id @default(autoincrement())
  playerTag       String   @db.VarChar(15)
  inicioSemana    String   @db.VarChar(10)
  clanTag         String   @db.VarChar(15)
  partidasGanadas Int      @default(0)
  partidasPerdidas Int     @default(0)
  cartasDonadas   Int      @default(0)
  trofeos         Int      @default(0)
  fama            Int      @default(0)
  createdAt       DateTime @default(now())

  @@unique([playerTag, inicioSemana])
  @@index([clanTag])
}
